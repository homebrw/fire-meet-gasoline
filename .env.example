# Copy to .env.local and fill in values from your Supabase project dashboard
# (Project Settings > API).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Sensitive: server-only, never expose to the client. Used for privileged
# operations (e.g. service-role Supabase calls). Keep out of version control.
SUPABASE_SERVICE_ROLE_KEY=

# Base URL of the deployed app, used to build the Google OAuth redirect URI
# (must match an authorized redirect URI on the Google Cloud OAuth client:
# <NEXT_PUBLIC_SITE_URL>/api/calendar/google/callback).
NEXT_PUBLIC_SITE_URL=

# Google Calendar integration (Settings > Intégrations). Create a Web
# application OAuth client in Google Cloud Console. Sensitive: never commit
# the client secret.
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

# Shared secret checked against the Authorization header on cron routes
# (e.g. /api/cron/renew-calendar-watch). Vercel Cron sends this automatically
# when CRON_SECRET is set as a project env var.
CRON_SECRET=

# Weather card (Today page). Open-Meteo needs no key. OpenWeatherMap
# requires a free account + API key subscribed to One Call API 4.0
# (https://openweathermap.org/api/one-call-4). Sensitive: server-only.
OPENWEATHER_API_KEY=
